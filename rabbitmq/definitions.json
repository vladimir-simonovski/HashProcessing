{
  "users": [
    {
      "name": "guest",
      "password": "guest",
      "tags": ["administrator"]
    },
    {
      "name": "hashprocessing",
      "password": "hashprocessing",
      "tags": []
    }
  ],
  "vhosts": [
    {
      "name": "/"
    }
  ],
  "permissions": [
    {
      "user": "guest",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    },
    {
      "user": "hashprocessing",
      "vhost": "/",
      "configure": "^(hash-processing|hash-daily-counts|hash-processing-dlq|hash-daily-counts-dlq)$",
      "write": "^(amq\\.default|dlx|hash-processing|hash-daily-counts)$",
      "read": "^(hash-processing|hash-daily-counts|hash-processing-dlq|hash-daily-counts-dlq)$"
    }
  ],
  "queues": [
    {
      "name": "hash-processing",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "dlx"
      }
    },
    {
      "name": "hash-daily-counts",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "dlx"
      }
    },
    {
      "name": "hash-processing-dlq",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "hash-daily-counts-dlq",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "exchanges": [
    {
      "name": "dlx",
      "vhost": "/",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "dlx",
      "vhost": "/",
      "destination": "hash-processing-dlq",
      "destination_type": "queue",
      "routing_key": "hash-processing",
      "arguments": {}
    },
    {
      "source": "dlx",
      "vhost": "/",
      "destination": "hash-daily-counts-dlq",
      "destination_type": "queue",
      "routing_key": "hash-daily-counts",
      "arguments": {}
    }
  ]
}
